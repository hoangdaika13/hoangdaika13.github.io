MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=hoangdaika13_site
JWT_SECRET=replace-with-at-least-32-random-characters
REALTIME_SERVER_URL=https://hoangdaika13-astra-realtime.onrender.com
ADMIN_EMAILS=owner@example.com
# Optional immutable MongoDB user IDs for break-glass owner access.
ADMIN_USER_IDS=
# Backward-compatible single address; ADMIN_EMAILS is preferred.
ADMIN_EMAIL=
ALLOWED_ORIGINS=https://nhhoang13all.xyz,https://www.nhhoang13all.xyz,https://hoangdaika13githubio.vercel.app
FRONTEND_URL=https://nhhoang13all.xyz
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://hoangdaika13githubio.vercel.app/api/auth/google/callback
# Authentication security. Generate AUTH_OTP_SECRET as a random 32+ character value.
AUTH_OTP_SECRET=
EMAIL_FROM=HH Platform <account@nhhoang13all.xyz>
PASSKEY_RP_ID=nhhoang13all.xyz
PASSKEY_RP_NAME=HH Platform
PASSKEY_ORIGINS=https://nhhoang13all.xyz,https://www.nhhoang13all.xyz
# Adaptive CAPTCHA is rendered only after suspicious failed sign-ins.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Dedicated OAuth callback for YouTube Publisher. Add this exact URL to the
# Google OAuth client's Authorized redirect URIs.
YOUTUBE_CALLBACK_URL=https://hoangdaika13githubio.vercel.app/api/youtube/oauth/callback
# Server-only encryption secret for Google access/refresh tokens (32+ random characters).
YOUTUBE_TOKEN_ENCRYPTION_KEY=
# Server-only keys for the integrated Search & Watch Center.
# Create these in Google Cloud / Programmable Search, then add them in Vercel.
YOUTUBE_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
# Server-only Gemini credentials. Prefer a comma or newline separated pool;
# never expose these values in browser JavaScript or commit them to Git.
GEMINI_API_KEYS=
GEMINI_MAX_KEY_ATTEMPTS=4
# Single-key fallback for an existing deployment.
GEMINI_API_KEY=
# Optional media overrides for the integrated Làm nhạc AI pipeline.
# GEMINI_API_KEYS is reused when these model IDs are available to the account.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_VIDEO_MODEL=veo-3.1-fast-generate-preview
ELEVENLABS_API_KEY=
ELEVEN_MUSIC_MODEL=music_v2
# A separate long-running FFmpeg service is optional for final 1–5 hour renders.
MUSIC_RENDER_API_URL=
MUSIC_RENDER_API_KEY=
# Preferred Google website search provider (Agent Search / Vertex AI Search).
# VERTEX_SEARCH_API_KEY can reuse GOOGLE_SEARCH_API_KEY after Discovery Engine API is allowed on that key.
VERTEX_SEARCH_PROJECT_ID=
VERTEX_SEARCH_LOCATION=global
VERTEX_SEARCH_APP_ID=
VERTEX_SEARCH_API_KEY=
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# Transactional thank-you email. Verify nhhoang13all.xyz in Resend first.
# The sender must belong to the verified domain; keys stay server-side in Vercel.
RESEND_API_KEY=
DONATION_FROM_EMAIL=Nhhoang <donate@nhhoang13all.xyz>
DONATION_REPLY_TO=
PUBLIC_SITE_URL=https://nhhoang13all.xyz
# Optional S3-compatible object storage for large images, video, audio and files.
# These values stay on Vercel; do not place them in browser JavaScript.
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
